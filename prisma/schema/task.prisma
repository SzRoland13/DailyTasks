model Task {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  priority    PriorityLevel @default(LOW)
  status    TaskStatus  @default(TODO)
  author      User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    Int
  createdAt   DateTime      @default(now())
  dueAt       DateTime?
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}
